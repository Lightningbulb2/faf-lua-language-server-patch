+        -- FAForever: FA scripts use --#region / -- #region.
+        -- The FA plugin.lua preprocesses '#' → '--', so '--#region' becomes '----region'
+        -- and the comment text becomes '--region'. Match all four variants:
+        --   "region ..."        standard LuaLS
+        --   "#region ..."       standard LuaLS
+        --   "--region ..."      FA: --#region after preprocessing
+        --   "-- #region ..."    FA: after preprocessing (already caught by '#region' above,
+        --                       but listed here for clarity)
+        local function isRegionStart(s)
+            return s:sub(1, #'region')    == 'region'
+                or s:sub(1, #'#region')   == '#region'
+                or s:sub(1, #'--region')  == '--region'
+                or s:sub(1, #'-- region') == '-- region'
+        end
+        local function isRegionEnd(s)
+            return s:sub(1, #'endregion')    == 'endregion'
+                or s:sub(1, #'#endregion')   == '#endregion'
+                or s:sub(1, #'--endregion')  == '--endregion'
+                or s:sub(1, #'-- endregion') == '-- endregion'
+        end
+        if isRegionStart(ltext) then
             if not status.regions then
                 status.regions = {}
             end
             status.regions[#status.regions+1] = source
-        elseif ltext:sub(1, #'endregion') == 'endregion'
-        or     ltext:sub(1, #'#endregion') == '#endregion' then
+        elseif isRegionEnd(ltext) then
             if not status.regions then
                 status.regions = {}
             end
