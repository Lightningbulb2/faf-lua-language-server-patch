build bin/lua-language-server.exe: copy $bin/lua-language-server.exe
build bin/main.lua: copy make/bootstrap.lua
build $builddir/build.ninja: configure make.lua make/detect_platform.lua $
    3rd/bee.lua/make.lua 3rd/bee.lua/compile/common.lua $
    3rd/bee.lua/compile/bootstrap.lua make/code_format.lua
build bootstrap: phony $bin/bootstrap
build copy_script: phony $bin/main.lua
build lua-language-server: phony $bin/lua-language-server.exe
build copy_lua-language-server: phony bin/lua-language-server.exe
build copy_bootstrap: phony bin/main.lua
build all: phony $bin/lua-language-server.exe copy_lua-language-server $
    copy_bootstrap
build bee-test: phony $builddir/_/bee-test
build unit-test: phony $builddir/_/unit-test
default all
